# ============================================================================
# Shared environment for the KapitanChat + StorageService stack.
# Copy to .env (`cp .env.example .env`) and fill in real values before running.
# ============================================================================

# --- Shared JWT secret -------------------------------------------------------
# The Django backend signs JWTs with SECRET_KEY; StorageService verifies them
# with the SAME key and algorithm. These MUST stay in sync.
SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256

# --- KapitanChat backend (Django) -------------------------------------------
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*
DJANGO_CORS_ALLOW_ALL=True
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_PORT=8000

# --- Redis (Django Channels layer) ------------------------------------------
REDIS_PASSWORD=change-me
# Host "redis" is the compose service name; keep the password in sync above.
REDIS_URL=redis://:change-me@redis:6379/0

# --- StorageService (FastAPI) -----------------------------------------------
STORAGE_PORT=8001
STORAGE_ORIGINS=*

# --- KapitanChat frontend (Vite, build-time) --------------------------------
# Baked into the static bundle at build time; must point to URLs reachable
# from the user's BROWSER (i.e. the published host ports).
VITE_BASEAPI=http://127.0.0.1:8000/api/
VITE_BASE_WS_URL=ws://127.0.0.1:8000/
VITE_BASE_FMS_URL=http://localhost:8001/api/file
FRONTEND_PORT=5173
